---
import EditorLayout from '../../layouts/EditorLayout.astro';
---

<EditorLayout title="Edit FAQ" currentTab="/admin/editor/faq">
  <h1 class="text-2xl font-bold mb-2">Edit FAQ</h1>
  <p class="text-muted-foreground mb-6">Question, answer, and optional SEO.</p>

  <form id="faq-form" class="space-y-8">
    <section class="rounded-lg border border-border bg-card p-6">
      <h2 class="text-lg font-semibold mb-4">Content</h2>
      <div class="space-y-4">
        <div>
          <label for="question" class="block text-sm font-medium mb-1">Question</label>
          <input type="text" id="question" name="question" required class="w-full px-3 py-2 rounded border border-border bg-background text-foreground" />
        </div>
        <div>
          <label for="answer" class="block text-sm font-medium mb-1">Answer</label>
          <textarea id="answer" name="answer" rows="6" class="w-full px-3 py-2 rounded border border-border bg-background text-foreground"></textarea>
        </div>
        <div>
          <label for="category" class="block text-sm font-medium mb-1">Category (optional)</label>
          <input type="text" id="category" name="category" class="w-full px-3 py-2 rounded border border-border bg-background text-foreground" />
        </div>
      </div>
    </section>

    <section class="rounded-lg border border-border bg-card p-6">
      <h2 class="text-lg font-semibold mb-4">SEO</h2>
      <div class="space-y-4">
        <div>
          <label for="meta_title" class="block text-sm font-medium mb-1">Meta title</label>
          <input type="text" id="meta_title" name="meta_title" class="w-full px-3 py-2 rounded border border-border bg-background text-foreground" />
        </div>
        <div>
          <label for="meta_description" class="block text-sm font-medium mb-1">Meta description</label>
          <textarea id="meta_description" name="meta_description" rows="2" class="w-full px-3 py-2 rounded border border-border bg-background text-foreground"></textarea>
        </div>
      </div>
    </section>

    <div class="flex gap-3">
      <button type="submit" class="px-5 py-2.5 rounded bg-primary text-primary-foreground font-medium">Save FAQ</button>
      <span id="faq-status" class="text-sm text-muted-foreground self-center"></span>
    </div>
  </form>
</EditorLayout>

<script>
  const form = document.getElementById('faq-form') as HTMLFormElement;
  const status = document.getElementById('faq-status');
  const headers = () => (window as unknown as { getEditorHeaders?: () => Record<string, string> }).getEditorHeaders?.() ?? {};
  const id = new URLSearchParams(typeof window !== 'undefined' ? window.location.search : '').get('id');

  if (id) {
    fetch(`/api/editor/faq/${id}`, { headers: headers() })
      .then(r => r.json())
      .then(data => {
        (form.querySelector('#question') as HTMLInputElement).value = data.question ?? '';
        (form.querySelector('#answer') as HTMLTextAreaElement).value = data.answer ?? '';
        (form.querySelector('#category') as HTMLInputElement).value = data.category ?? '';
        (form.querySelector('#meta_title') as HTMLInputElement).value = data.meta_title ?? '';
        (form.querySelector('#meta_description') as HTMLTextAreaElement).value = data.meta_description ?? '';
      });
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const body = {
      question: fd.get('question'),
      answer: fd.get('answer') || '',
      category: fd.get('category') || null,
      order_num: 0,
      meta_title: fd.get('meta_title') || null,
      meta_description: fd.get('meta_description') || null,
    };
    const url = id ? `/api/editor/faq/${id}` : '/api/editor/faq';
    const method = id ? 'PUT' : 'POST';
    const res = await fetch(url, { method, headers: headers(), body: JSON.stringify(body) });
    if (status) status.textContent = res.ok ? 'Saved.' : 'Failed to save.';
    if (res.ok && !id) {
      const d = await res.json();
      window.location.href = `/admin/editor/faq-edit?id=${d.id}`;
    }
  });
</script>
