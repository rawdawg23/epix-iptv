---
import EditorLayout from '../../../layouts/EditorLayout.astro';
---

<EditorLayout title="Dashboard" currentTab="/admin/editor">
  <h1 class="text-2xl font-bold mb-2">Dashboard</h1>
  <p class="text-muted-foreground mb-8">Manage your site content, SEO, and settings in one place.</p>

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
    <a href="/admin/editor/settings" class="block p-5 rounded-lg border border-border bg-card hover:border-primary transition-colors">
      <span class="text-2xl mb-2 block">⚙</span>
      <h2 class="font-semibold mb-1">Site settings</h2>
      <p class="text-sm text-muted-foreground">Brand name, contact, payment options</p>
    </a>
    <a href="/admin/editor/pages" class="block p-5 rounded-lg border border-border bg-card hover:border-primary transition-colors">
      <span class="text-2xl mb-2 block">📄</span>
      <h2 class="font-semibold mb-1">Pages</h2>
      <p class="text-sm text-muted-foreground">Create and edit pages</p>
    </a>
    <a href="/admin/editor/pricing" class="block p-5 rounded-lg border border-border bg-card hover:border-primary transition-colors">
      <span class="text-2xl mb-2 block">💰</span>
      <h2 class="font-semibold mb-1">Pricing</h2>
      <p class="text-sm text-muted-foreground">Plans and prices</p>
    </a>
    <a href="/admin/editor/faq" class="block p-5 rounded-lg border border-border bg-card hover:border-primary transition-colors">
      <span class="text-2xl mb-2 block">❓</span>
      <h2 class="font-semibold mb-1">FAQ</h2>
      <p class="text-sm text-muted-foreground">Questions and answers</p>
    </a>
    <a href="/admin/editor/support" class="block p-5 rounded-lg border border-border bg-card hover:border-primary transition-colors">
      <span class="text-2xl mb-2 block">💬</span>
      <h2 class="font-semibold mb-1">Support channels</h2>
      <p class="text-sm text-muted-foreground">Telegram & WhatsApp on/off and links</p>
    </a>
    <a href="/admin/editor/seo" class="block p-5 rounded-lg border border-border bg-card hover:border-primary transition-colors">
      <span class="text-2xl mb-2 block">🔍</span>
      <h2 class="font-semibold mb-1">SEO</h2>
      <p class="text-sm text-muted-foreground">Meta titles, descriptions, defaults</p>
    </a>
  </div>
</EditorLayout>
