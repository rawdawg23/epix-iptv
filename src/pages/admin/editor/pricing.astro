---
import EditorLayout from '../../layouts/EditorLayout.astro';
---

<EditorLayout title="Pricing" currentTab="/admin/editor/pricing">
  <h1 class="text-2xl font-bold mb-2">Pricing</h1>
  <p class="text-muted-foreground mb-6">Manage your plans and prices. Each plan can have its own SEO.</p>

  <div class="mb-6">
    <a href="/admin/editor/plan-edit" class="inline-flex items-center gap-2 px-4 py-2 rounded bg-primary text-primary-foreground font-medium text-sm">+ Add plan</a>
  </div>

  <div id="pricing-list" class="space-y-2">
    <p class="text-muted-foreground">Loading…</p>
  </div>
</EditorLayout>

<script>
  const list = document.getElementById('pricing-list');
  const headers = () => (window as unknown as { getEditorHeaders?: () => Record<string, string> }).getEditorHeaders?.() ?? {};
  function esc(s: string) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

  async function load() {
    const res = await fetch('/api/editor/pricing', { headers: headers() });
    const data = await res.json();
    if (!list) return;
    if (!data.plans?.length) {
      list.innerHTML = '<p class="text-muted-foreground">No plans yet. Add one above.</p>';
      return;
    }
    list.innerHTML = data.plans.map((p: { id: string; name: string; price: number; currency: string }) =>
      `<div class="flex items-center justify-between p-4 rounded-lg border border-border bg-card">
        <span class="font-medium">${esc(p.name)}</span>
        <span class="text-muted-foreground">${p.currency} ${p.price}</span>
        <a href="/admin/editor/plan-edit?id=${encodeURIComponent(p.id)}" class="text-sm text-primary hover:underline">Edit</a>
      </div>`
    ).join('');
  }
  load();
</script>
