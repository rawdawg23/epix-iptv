---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEO from '../../components/SEO.astro';
---

<BaseLayout>
  <SEO slot="head" title="Checkout" description="Complete your order." />
  <section class="section-container">
    <div class="container mx-auto px-4 max-w-xl">
      <h1 class="text-2xl font-bold mb-6">Checkout</h1>
      <form id="checkout-form" class="space-y-6">
        <div>
          <label for="email" class="block text-sm font-medium mb-1">Email *</label>
          <input type="email" id="email" name="email" required class="w-full px-3 py-2 rounded border border-border bg-background text-foreground" />
        </div>
        <fieldset class="rounded-lg border border-border p-4">
          <legend class="font-medium">Shipping address</legend>
          <div class="mt-2 space-y-2">
            <input type="text" name="name" placeholder="Full name" class="w-full px-3 py-2 rounded border border-border bg-background text-foreground" />
            <input type="text" name="address" placeholder="Address" class="w-full px-3 py-2 rounded border border-border bg-background text-foreground" />
            <div class="grid grid-cols-2 gap-2">
              <input type="text" name="city" placeholder="City" class="px-3 py-2 rounded border border-border bg-background text-foreground" />
              <input type="text" name="postal" placeholder="Postal code" class="px-3 py-2 rounded border border-border bg-background text-foreground" />
            </div>
            <input type="text" name="country" placeholder="Country" class="w-full px-3 py-2 rounded border border-border bg-background text-foreground" />
          </div>
        </fieldset>
        <div>
          <label for="coupon" class="block text-sm font-medium mb-1">Coupon (optional)</label>
          <input type="text" id="coupon" name="coupon" class="w-full px-3 py-2 rounded border border-border bg-background text-foreground" />
        </div>
        <div>
          <label for="notes" class="block text-sm font-medium mb-1">Order notes</label>
          <textarea id="notes" name="notes" rows="2" class="w-full px-3 py-2 rounded border border-border bg-background text-foreground"></textarea>
        </div>
        <button type="submit" class="w-full px-6 py-3 rounded bg-primary text-primary-foreground font-medium">Place order</button>
        <p id="checkout-status" class="text-sm text-muted-foreground"></p>
      </form>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('checkout-form') as HTMLFormElement;
  const status = document.getElementById('checkout-status');
  const cart = JSON.parse(localStorage.getItem('store_cart') || '[]');
  if (!cart.length && form) {
    form.innerHTML = '<p class="text-muted-foreground">Your cart is empty. <a href="/store" class="text-primary hover:underline">Browse store</a>.</p>';
  }
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const email = fd.get('email') as string;
    const items = cart.map((i: { productId: string; quantity: number }) => ({ productId: i.productId, quantity: i.quantity }));
    const shippingAddress = {
      name: fd.get('name'),
      address: fd.get('address'),
      city: fd.get('city'),
      postal: fd.get('postal'),
      country: fd.get('country'),
    };
    const res = await fetch('/api/store/checkout', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        email,
        items,
        shippingAddress,
        billingAddress: shippingAddress,
        coupon: (fd.get('coupon') as string)?.trim() || undefined,
        notes: (fd.get('notes') as string)?.trim() || undefined,
      }),
    });
    const data = await res.json();
    if (status) status.textContent = res.ok ? '' : (data.error || 'Checkout failed');
    if (res.ok && data.confirmationUrl) {
      localStorage.removeItem('store_cart');
      window.location.href = data.confirmationUrl;
    }
  });
</script>
